# Frontend (Vite)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Optional: if empty, production uses /api/chat and development uses the remote backend
VITE_AI_API_URL=

# Serverless (Vercel Function)
# Preferred provider (recommended)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Alternative provider
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_REFERER=
OPENROUTER_TITLE=
CHAT_LOCAL_FIRST=true

# Optional fallback backend for /api/chat if OPENAI_API_KEY is not configured
AI_BACKEND_URL=
